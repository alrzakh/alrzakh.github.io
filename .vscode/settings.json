{
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "files.autoSave": "onWindowChange",
    "files.exclude": {
        "**/.git": true,
        "**/.DS_Store": true,
        "**/node_modules": true
    },
    "html.format.enable": true,
    "scss.validate": true,
    "javascript.validate.enable": true,
    "git.ignoreLimitWarning": true
}